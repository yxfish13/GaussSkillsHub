generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillVersionStatus {
  draft
  submitted
  approved
  rejected
  archived
}

enum ReviewActorType {
  system
  admin
}

enum SkillVoteValue {
  up
  down
}

enum SkillVisibility {
  public
  hidden
}

model AdminUser {
  id           String             @id @default(cuid())
  username     String             @unique
  passwordHash String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  reviewLogs   VersionReviewLog[] @relation("AdminActorLogs")
}

model Skill {
  id                      String         @id @default(cuid())
  slug                    String         @unique
  visibility              SkillVisibility @default(public)
  totalDownloadCount      Int            @default(0)
  totalUpvoteCount        Int            @default(0)
  totalDownvoteCount      Int            @default(0)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  latestApprovedVersionId String?        @unique
  latestApprovedVersion   SkillVersion?  @relation("LatestApprovedVersion", fields: [latestApprovedVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  versions                SkillVersion[]
  comments                SkillComment[]
  votes                   SkillVote[]
}

model SkillVersion {
  id              String             @id @default(cuid())
  skillId          String
  version          String
  title            String
  summary          String
  markdownContent  String
  downloadCount    Int                @default(0)
  coverImagePath   String?
  coverImageName   String?
  bundlePath       String?
  bundleName       String?
  submitterName    String?
  submitterContact String?
  status           SkillVersionStatus @default(approved)
  reviewNotes      String?
  submittedAt      DateTime           @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  skill            Skill              @relation(fields: [skillId], references: [id], onDelete: Cascade)
  reviewLogs       VersionReviewLog[]
  currentForSkill  Skill?             @relation("LatestApprovedVersion")

  @@unique([skillId, version])
  @@index([skillId, status, createdAt])
}

model VersionReviewLog {
  id             String             @id @default(cuid())
  skillVersionId String
  fromStatus     SkillVersionStatus?
  toStatus       SkillVersionStatus
  note           String?
  actorType      ReviewActorType    @default(system)
  actorId        String?
  createdAt      DateTime           @default(now())
  actor          AdminUser?         @relation("AdminActorLogs", fields: [actorId], references: [id], onDelete: SetNull)
  skillVersion   SkillVersion       @relation(fields: [skillVersionId], references: [id], onDelete: Cascade)

  @@index([skillVersionId, createdAt])
}

model SkillComment {
  id         String   @id @default(cuid())
  skillId    String
  authorName String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId, createdAt])
}

model SkillVote {
  id               String         @id @default(cuid())
  skillId          String
  browserTokenHash String
  value            SkillVoteValue
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  skill            Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, browserTokenHash])
  @@index([skillId, value])
}
