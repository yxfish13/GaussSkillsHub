generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillVersionStatus {
  draft
  submitted
  approved
  rejected
  archived
}

enum ReviewActorType {
  system
  admin
}

model AdminUser {
  id           String             @id @default(cuid())
  username     String             @unique
  passwordHash String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  reviewLogs   VersionReviewLog[] @relation("AdminActorLogs")
}

model Skill {
  id                      String         @id @default(cuid())
  slug                    String         @unique
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  latestApprovedVersionId String?        @unique
  latestApprovedVersion   SkillVersion?  @relation("LatestApprovedVersion", fields: [latestApprovedVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  versions                SkillVersion[]
}

model SkillVersion {
  id              String             @id @default(cuid())
  skillId          String
  version          String
  title            String
  summary          String
  markdownContent  String
  coverImagePath   String?
  coverImageName   String?
  bundlePath       String?
  bundleName       String?
  submitterName    String?
  submitterContact String?
  status           SkillVersionStatus @default(submitted)
  reviewNotes      String?
  submittedAt      DateTime           @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  skill            Skill              @relation(fields: [skillId], references: [id], onDelete: Cascade)
  reviewLogs       VersionReviewLog[]
  currentForSkill  Skill?             @relation("LatestApprovedVersion")

  @@unique([skillId, version])
  @@index([skillId, status, createdAt])
}

model VersionReviewLog {
  id             String             @id @default(cuid())
  skillVersionId String
  fromStatus     SkillVersionStatus?
  toStatus       SkillVersionStatus
  note           String?
  actorType      ReviewActorType    @default(system)
  actorId        String?
  createdAt      DateTime           @default(now())
  actor          AdminUser?         @relation("AdminActorLogs", fields: [actorId], references: [id], onDelete: SetNull)
  skillVersion   SkillVersion       @relation(fields: [skillVersionId], references: [id], onDelete: Cascade)

  @@index([skillVersionId, createdAt])
}
